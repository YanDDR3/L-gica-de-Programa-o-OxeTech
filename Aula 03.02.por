programa {
  funcao inicio() {
    
    inteiro numero

    escreva("digite um número: ")
    leia (numero)

    se (numero == 0){
      escreva("o número é Zero!")
    }
    senao se (numero > 0){
           escreva(numero, " é positivo!")
    }
      senao {(escreva(numero, " é negativo!"))
      }
    }
  }
