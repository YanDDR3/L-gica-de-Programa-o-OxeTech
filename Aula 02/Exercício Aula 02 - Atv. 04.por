programa {
  funcao inicio() {
    
    real angulo1
    real angulo2 
    real triangulo = 180

    //entrada de dados
    escreva("Digite o primeiro ângulo: ")
    leia (angulo1)

    escreva("Digite o segundo ângulo: ")
    leia (angulo2)

    real angulo3
    angulo3 = angulo1 + angulo2
 real resposta = triangulo - angulo3
    //saída de dados

escreva("O terceiro ângulo do triângulo é: ", resposta)
   
  }
}
